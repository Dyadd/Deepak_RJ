---
import ViewTracker from '../components/ViewTracker.astro';

interface Props {
  title: string;
  description?: string;
  activeNav?: 'home' | 'blog' | 'about';
}

const { title, description = "Writing on medical AI and neuropsychiatry", activeNav } = Astro.props;
const base = import.meta.env.BASE_URL;

// Set your Umami website ID here once you have one:
const umamiWebsiteId = '859aec8b-0917-4835-8813-9e7cb9d8d1ae';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700;800&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href={`${base}`} class="nav-brand">Deepak RJ</a>
        <ul class="nav-links">
          <li><a href={`${base}`} class={activeNav === 'home' ? 'active' : ''}>Home</a></li>
          <li><a href={`${base}blog/`} class={activeNav === 'blog' ? 'active' : ''}>Blog</a></li>
          <li><a href={`${base}about/`} class={activeNav === 'about' ? 'active' : ''}>About</a></li>
          <li><a href="https://github.com/Dyadd" target="_blank" rel="noopener">GitHub</a></li>
          <li><a href="https://x.com/dyad_rj" target="_blank" rel="noopener">Twitter</a></li>
        </ul>
      </div>
    </nav>

    <slot />

    <footer class="footer">
      <div class="footer-inner">
        <span>&copy; {new Date().getFullYear()} Deepak RJ</span>
        <span>Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a></span>
      </div>
    </footer>
    <ViewTracker websiteId={umamiWebsiteId} />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

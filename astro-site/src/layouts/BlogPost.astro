---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  categories?: string[];
  author?: string;
}

const { title, description, date, categories = [], author = 'Deepak RJ' } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const email = 'deepak.rj@example.com';
const subject = encodeURIComponent(`Re: ${title}`);
const mailtoLink = `mailto:${email}?subject=${subject}`;
---

<BaseLayout title={`${title} — Deepak RJ`} description={description} activeNav="blog">
  <main>
    <article class="container">
      <header class="article-header">
        <h1>{title}</h1>
        <div class="post-meta">
          <span>{author}</span>
          <span>&middot;</span>
          <time datetime={date}>{formattedDate}</time>
          {categories.length > 0 && (
            <>
              <span>&middot;</span>
              {categories.map(cat => (
                <span class="post-tag">{cat}</span>
              ))}
            </>
          )}
        </div>
      </header>

      <div class="article-content">
        <slot />
      </div>

      <div class="contact-prompt">
        <p>Have thoughts on this? I'd love to hear from you.</p>
        <a href={mailtoLink}>Send me an email &rarr;</a>
      </div>

      <div class="giscus-wrapper">
        <script
          src="https://giscus.app/client.js"
          data-repo="dyadd/Deepak_RJ"
          data-repo-id=""
          data-category="Blog Comments"
          data-category-id=""
          data-mapping="pathname"
          data-strict="0"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="top"
          data-theme="light"
          data-lang="en"
          data-loading="lazy"
          crossorigin="anonymous"
          async
        ></script>
      </div>
    </article>
  </main>
</BaseLayout>

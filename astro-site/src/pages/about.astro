---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="About — Deepak RJ" activeNav="about">
  <main>
    <div class="container">
      <h1>About</h1>

      <div class="about-layout">
        <img src={`${base}profile.jpg`} alt="Deepak RJ" class="about-photo" />
        <div class="about-content">
          <p>
            I'm a junior doctor practising in Australia, completing my MD at Monash
            University. I've studied CS informally, and ML formally at Stanford.
          </p>
          <p>
            My primary interests lie in clinical translation/biodesign, medical AI projects,
            computational medicine, computational phenomenology, and computational psychiatry.
          </p>
          <p>
            Other interests include complex systems modelling and dynamical systems.
            Currently reading <em>Conscious Mind, Resonant Brain</em> by Stephen Grossberg.
          </p>

          <div class="about-links">
            <a href="https://x.com/dyad_rj" target="_blank" rel="noopener">Twitter</a>
            <a href="https://www.linkedin.com/in/deepak-r-j/" target="_blank" rel="noopener">LinkedIn</a>
            <a href="https://github.com/Dyadd" target="_blank" rel="noopener">GitHub</a>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

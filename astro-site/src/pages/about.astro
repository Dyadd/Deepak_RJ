---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="About — Deepak RJ" activeNav="about">
  <main>
    <div class="container">
      <h1>About</h1>

      <div class="about-layout">
        <img src={`${base}profile.jpg`} alt="Deepak RJ" class="about-photo" />
        <div class="about-content">
          <p>
            I write about emerging medical AI for clinicians and about medicine for data
            scientists. My goal is to help us actualise AI for medicine, from biomedical
            research to clinical practice, for the safe and productive merge of data science
            and medicine.
          </p>
          <p>
            As a medical student, AI researcher, and long-term insight meditator, I track
            how technology is reshaping healthcare while exploring deeper questions about
            attention, identity, computational psychiatry and what it means to understand minds.
            I work at the tight-knit <a href="https://www.linkedin.com/company/monash-medical-technology-lab/" target="_blank" rel="noopener">MMTL</a>.
          </p>
          <p>
            Other interests include complex systems, modelling and computational psychiatry.
          </p>

          <div class="about-links">
            <a href="https://x.com/dyad_rj" target="_blank" rel="noopener">Twitter</a>
            <a href="https://www.linkedin.com/in/deepak-r-j/" target="_blank" rel="noopener">LinkedIn</a>
            <a href="https://github.com/Dyadd" target="_blank" rel="noopener">GitHub</a>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

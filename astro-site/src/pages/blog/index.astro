---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const base = import.meta.env.BASE_URL;

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
---

<BaseLayout title="Blog — Deepak RJ" description="Writing on medical AI and neuropsychiatry" activeNav="blog">
  <main>
    <div class="container">
      <h1>Blog</h1>
      <p style="color: var(--color-text-secondary); margin-bottom: 2em;">
        Writing on medical AI, human-computer interaction, and neuropsychiatry.
      </p>

      <ul class="post-list">
        {posts.map(post => (
          <li class="post-item">
            <a href={`${base}blog/${post.id}/`}>
              <div class="post-title">{post.data.title}</div>
              <div class="post-meta">
                <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
                {post.data.categories.map(cat => (
                  <span class="post-tag">{cat}</span>
                ))}
              </div>
              {post.data.description && (
                <div class="post-description">{post.data.description}</div>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </main>
</BaseLayout>

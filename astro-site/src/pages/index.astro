---
import BaseLayout from '../layouts/BaseLayout.astro';
import MostViewed from '../components/MostViewed.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

const base = import.meta.env.BASE_URL;

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
---

<BaseLayout title="Deepak RJ" activeNav="home">
  <main>
    <div class="container">
      <div class="home-header">
        <img src={`${base}profile.jpg`} alt="Deepak RJ" class="home-avatar" />
        <h1>Deepak RJ</h1>
        <p class="home-interests">
          Translational Medical AI &middot; Computational Medicine &middot; Computational Phenomenology &middot; Computational Psychiatry
        </p>
        <div class="home-links">
          <a href="https://x.com/dyad_rj" target="_blank" rel="noopener">Twitter</a>
          <a href="https://www.linkedin.com/in/deepak-r-j/" target="_blank" rel="noopener">LinkedIn</a>
          <a href="https://github.com/Dyadd" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>

      <div class="home-grid">
        <div class="home-section">
          <div class="section-label">Current Projects</div>
          <ul class="project-list">
            <li>
              <a href="https://bloomed.study" target="_blank" rel="noopener" class="project-name">Bloomed</a>
              <div class="project-desc">Mapping the ontology of medicine and a student's model to maximise yield per study session.</div>
            </li>
            <li>
              <a href="https://loopymind.com" target="_blank" rel="noopener" class="project-name">loopymind</a>
              <div class="project-desc">Building a culture of phenomenological exploration, and mapping how humans' minds work at scale through phenomenological inquiry and meditation.</div>
            </li>
            <li>
              <a href="https://www.nexusmedtech.org" target="_blank" rel="noopener" class="project-name">Nexus</a>
              <div class="project-desc">Creating the nexus for all things medical AI, from education to research news.</div>
            </li>
            <li>
              <div class="project-name">Clarity</div>
              <div class="project-desc">MIME-funded point-of-care clinical decision support for doctors.</div>
            </li>
            <li>
              <a href="https://www.gamsnack.com" target="_blank" rel="noopener" class="project-name">GAMSnack</a>
              <div class="project-desc">Mapping cognitive states in GAMSAT students for AI-powered personalised tutoring.</div>
            </li>
          </ul>
        </div>

        <div class="home-section">
          <div class="section-label">Most Viewed</div>
          <MostViewed base={base} />

          <div class="section-label" style="margin-top: 1.5em;">Most Recent</div>
          <ul class="post-list">
            {posts.map(post => (
              <li class="post-item">
                <a href={`${base}blog/${post.id}/`}>
                  <div class="post-title">{post.data.title}</div>
                  <div class="post-meta">
                    <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
                  </div>
                </a>
              </li>
            ))}
          </ul>
          <p style="margin-top: 1em;">
            <a href={`${base}blog/`}>All posts &rarr;</a>
          </p>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
